---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubCard from '../components/HubCard.astro';
import ArticleCard from '../components/ArticleCard.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Finaneo",
  "url": "https://finaneo.fr",
  "logo": "https://finaneo.fr/logo-finaneo.svg",
  "description": "Comparez les crédits, assurances et placements. Simulateurs gratuits, guides experts et conseils personnalisés pour optimiser vos finances.",
  "sameAs": []
};

const hubs = [
  { title: 'Crédit immobilier', description: 'Comparez les taux, simulez vos mensualités et trouvez le prêt le plus avantageux.', href: '/credit-immobilier/', icon: '🏠', illustration: '/illustrations/credit-immo.svg', accent: '#3B82F6' },
  { title: 'Assurance emprunteur', description: 'Réduisez le coût de votre assurance de prêt. Jusqu\'à 15 000 € d\'économies.', href: '/assurance-emprunteur/', icon: '🛡️', accent: '#06B6D4' },
  { title: 'Épargne', description: 'Livret A, LDDS, assurance-vie : les meilleurs placements pour votre épargne.', href: '/epargne/', icon: '💰', illustration: '/illustrations/epargne.svg', accent: '#8B5CF6' },
  { title: 'Investissement', description: 'PEA, ETF, SCPI : construisez un portefeuille adapté à votre profil.', href: '/investissement/', icon: '📈', illustration: '/illustrations/investissement.svg', accent: '#22C55E' },
  { title: 'Défiscalisation', description: 'Pinel, PER, LMNP : identifiez les dispositifs pour réduire vos impôts.', href: '/defiscalisation/', icon: '📋', illustration: '/illustrations/defiscalisation.svg', accent: '#F43F5E' },
  { title: 'Rachat de crédit', description: 'Regroupez vos crédits pour alléger vos mensualités. Simulation gratuite.', href: '/rachat-credit/', icon: '🔄', accent: '#F59E0B' },
];

const stats = [
  { value: '12 000+', label: 'lecteurs mensuels', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
  { value: '6', label: 'thématiques', icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10' },
  { value: '100%', label: 'guides gratuits', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
];
---

<BaseLayout
  title="Finaneo — Vos finances, enfin claires"
  description="Comparez les crédits, assurances et placements. Simulateurs gratuits, guides experts et conseils personnalisés pour optimiser vos finances."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-navy via-navy-light to-navy overflow-hidden">
    <!-- Geometric grid overlay -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <!-- Gradient orb -->
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-gold/5 rounded-full blur-3xl"></div>

    <div class="container-site relative z-10 pt-32 pb-20 md:pt-40 md:pb-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-8">
            <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
            <span class="text-white/80 text-sm font-medium">Média financier indépendant</span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-display font-extrabold text-white leading-[1.1] mb-6">
            Vos finances,<br/>
            <span class="text-gold">enfin claires</span>
          </h1>
          <p class="text-lg md:text-xl text-white/70 max-w-lg mb-10 leading-relaxed">
            Comparez les meilleures offres, simulez vos projets et optimisez chaque euro. Guides experts et outils gratuits.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/simulateurs/credit-immobilier/" class="btn-primary text-base">
              Simuler mon crédit
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/guides/" class="btn-ghost text-base">
              Lire nos guides
            </a>
          </div>
        </div>
        <div class="hidden lg:flex justify-center">
          <img src="/illustrations/hero-chart.svg" alt="Graphique de croissance financière" class="w-full max-w-md" />
        </div>
      </div>

      <!-- Stats bar -->
      <div class="mt-16 md:mt-20 grid grid-cols-3 gap-6 max-w-2xl">
        {stats.map((stat) => (
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stat.icon} />
              </svg>
            </div>
            <div>
              <div class="text-white font-bold text-lg leading-tight counter" data-target={stat.value}>{stat.value}</div>
              <div class="text-white/50 text-xs">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hub Cards -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="text-center mb-14 reveal">
        <h2 class="text-h2 text-navy mb-4">Tous nos univers financiers</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Explorez nos guides, comparateurs et simulateurs par thématique pour prendre les bonnes décisions.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
        {hubs.map((hub) => (
          <HubCard
            title={hub.title}
            description={hub.description}
            href={hub.href}
            icon={hub.icon}
            illustration={hub.illustration}
            accentColor={hub.accent}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Simulator CTA -->
  <section class="section-padding bg-surface">
    <div class="container-site">
      <div class="bg-white rounded-3xl shadow-card border border-gray-100 p-8 md:p-14 flex flex-col md:flex-row items-center gap-10 reveal">
        <div class="flex-1">
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-gold bg-gold/10 rounded-full px-4 py-1.5 mb-5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            Outil gratuit
          </span>
          <h2 class="text-h2 text-navy mb-4">
            Calculez votre mensualité de crédit immobilier
          </h2>
          <p class="text-gray-500 leading-relaxed mb-8 max-w-lg">
            Renseignez le montant, la durée et le taux pour obtenir instantanément
            vos mensualités et le coût total du crédit.
          </p>
          <a href="/simulateurs/credit-immobilier/" class="btn-secondary">
            Lancer la simulation
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
        <div class="flex-shrink-0">
          <img src="/illustrations/simulateur.svg" alt="Simulateur" class="w-48 md:w-56" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Pourquoi Finaneo -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="text-center mb-14 reveal">
        <h2 class="text-h2 text-navy mb-4">Pourquoi choisir Finaneo ?</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Une plateforme conçue pour vous aider à prendre des décisions financières éclairées.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
        <div class="text-center p-8 rounded-2xl hover:bg-surface transition-colors">
          <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="text-h3 text-navy mb-3">Comparateur indépendant</h3>
          <p class="text-gray-500 leading-relaxed">
            Aucun établissement ne nous rémunère pour mettre en avant ses produits. Nos comparatifs sont objectifs.
          </p>
        </div>
        <div class="text-center p-8 rounded-2xl hover:bg-surface transition-colors">
          <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-h3 text-navy mb-3">Simulateurs gratuits</h3>
          <p class="text-gray-500 leading-relaxed">
            Tous nos outils sont accessibles sans inscription et sans engagement. Calculez, comparez, décidez.
          </p>
        </div>
        <div class="text-center p-8 rounded-2xl hover:bg-surface transition-colors">
          <div class="w-16 h-16 bg-gold/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-h3 text-navy mb-3">Guides experts</h3>
          <p class="text-gray-500 leading-relaxed">
            Des articles rédigés par des spécialistes pour vous accompagner du premier achat à la retraite.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles récents -->
  <section class="section-padding bg-surface">
    <div class="container-site">
      <div class="flex items-end justify-between mb-12 reveal">
        <div>
          <h2 class="text-h2 text-navy mb-2">Derniers articles</h2>
          <p class="text-gray-500">Conseils et analyses pour piloter vos finances.</p>
        </div>
        <a href="/guides/" class="hidden md:inline-flex items-center gap-1.5 text-gold font-semibold hover:gap-2.5 transition-all">
          Tous les guides
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal">
        <ArticleCard
          title="Comment calculer sa capacité d'emprunt en 2026"
          description="Taux d'endettement, revenus, apport : tout ce qu'il faut savoir pour maximiser votre budget immobilier."
          slug="capacite-emprunt-2026"
          category="Crédit immobilier"
          date="2026-03-15"
          readingTime="8 min"
        />
        <ArticleCard
          title="PEA ou assurance-vie : que choisir en 2026 ?"
          description="Fiscalité, rendement, liquidité : notre comparatif détaillé pour arbitrer entre ces deux enveloppes."
          slug="pea-ou-assurance-vie-2026"
          category="Investissement"
          date="2026-03-10"
          readingTime="7 min"
        />
        <ArticleCard
          title="Rachat de crédit : comment économiser sur ses mensualités"
          description="Regrouper ses crédits peut faire baisser vos mensualités de 30 à 60 %. Guide complet."
          slug="rachat-credit-economies"
          category="Rachat de crédit"
          date="2026-03-05"
          readingTime="6 min"
        />
      </div>
      <div class="text-center mt-8 md:hidden">
        <a href="/guides/" class="inline-flex items-center gap-1.5 text-gold font-semibold">
          Tous les guides
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Scroll reveal
  const revealElements = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  revealElements.forEach((el) => observer.observe(el));
</script>
