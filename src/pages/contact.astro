---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="Contactez Finaneo"
  description="Une question ? Contactez l'équipe Finaneo. Nous vous répondons sous 24h."
>
  <section class="section-padding">
    <div class="container-narrow">
      <Breadcrumb items={[{ label: 'Contact' }]} />

      <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-extrabold text-navy mb-4">
          Contactez-nous
        </h1>
        <p class="text-lg text-gray-600 mb-10">
          Une question sur nos guides, nos simulateurs ou un sujet financier ? Remplissez le formulaire ci-dessous, notre équipe vous répond sous 24 heures.
        </p>

        <form
          name="contact"
          method="POST"
          action="/contact-merci/"
          data-netlify="true"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="nom" class="block text-sm font-medium text-dark mb-1">Nom complet</label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none transition"
                placeholder="Jean Dupont"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-1">Adresse email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none transition"
                placeholder="jean@email.com"
              />
            </div>
          </div>

          <div>
            <label for="telephone" class="block text-sm font-medium text-dark mb-1">Téléphone <span class="text-gray-400">(facultatif)</span></label>
            <input
              type="tel"
              id="telephone"
              name="telephone"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none transition"
              placeholder="06 12 34 56 78"
            />
          </div>

          <div>
            <label for="sujet" class="block text-sm font-medium text-dark mb-1">Sujet</label>
            <select
              id="sujet"
              name="sujet"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none transition bg-white"
            >
              <option value="" disabled selected>Choisissez un sujet</option>
              <option value="Crédit immobilier">Crédit immobilier</option>
              <option value="Assurance">Assurance</option>
              <option value="Épargne">Épargne</option>
              <option value="Investissement">Investissement</option>
              <option value="Défiscalisation">Défiscalisation</option>
              <option value="Rachat de crédit">Rachat de crédit</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Votre message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none transition resize-none"
              placeholder="Décrivez votre demande..."
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full">
            Envoyer mon message
          </button>

          <p class="text-xs text-gray-400 text-center">
            En soumettant ce formulaire, vous acceptez notre <a href="/politique-confidentialite/" class="underline hover:text-gold">politique de confidentialité</a>.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
