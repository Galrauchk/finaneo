---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<BaseLayout
  title="Simulateurs financiers gratuits"
  description="Calculez vos mensualités de crédit, simulez la croissance de votre épargne. Outils gratuits et sans inscription."
>
  <section class="section-padding">
    <div class="container-narrow">
      <Breadcrumb items={[{ label: 'Simulateurs' }]} />

      <h1 class="text-3xl md:text-4xl font-extrabold text-navy mb-4">
        Simulateurs financiers gratuits
      </h1>
      <p class="text-lg text-gray-600 mb-12 max-w-2xl">
        Estimez vos mensualités de crédit ou la croissance de votre épargne en quelques clics. Nos simulateurs sont gratuits, sans inscription et sans engagement.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Simulateur Crédit Immobilier -->
        <a
          href="/simulateurs/credit-immobilier/"
          class="group block bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg hover:border-gold transition-all duration-300"
        >
          <div class="w-14 h-14 bg-navy/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-gold/20 transition-colors">
            <svg class="w-7 h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-navy mb-2 group-hover:text-gold transition-colors">
            Simulateur de crédit immobilier
          </h2>
          <p class="text-gray-600 text-sm mb-4">
            Calculez vos mensualités en fonction du montant emprunté, de la durée et du taux d'intérêt. Obtenez une estimation précise de votre capacité d'emprunt.
          </p>
          <span class="inline-flex items-center text-sm font-semibold text-gold">
            Lancer la simulation
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>

        <!-- Simulateur Épargne -->
        <a
          href="/simulateurs/epargne/"
          class="group block bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg hover:border-gold transition-all duration-300"
        >
          <div class="w-14 h-14 bg-navy/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-gold/20 transition-colors">
            <svg class="w-7 h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-navy mb-2 group-hover:text-gold transition-colors">
            Simulateur d'épargne
          </h2>
          <p class="text-gray-600 text-sm mb-4">
            Projetez la croissance de votre épargne dans le temps. Capital initial, versements mensuels, taux et durée : visualisez votre patrimoine futur.
          </p>
          <span class="inline-flex items-center text-sm font-semibold text-gold">
            Lancer la simulation
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
