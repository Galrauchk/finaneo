---
interface Props {
  formTitle?: string;
  submitLabel?: string;
  source: 'credit-immobilier' | 'defiscalisation' | 'rachat-credit';
}

const {
  formTitle = 'Demandez votre simulation gratuite',
  submitLabel = 'Envoyer ma demande',
  source,
} = Astro.props;

const id = `lead-${source}`;
---

<div class="bg-white rounded-2xl p-8 shadow-card">
  <h3 class="text-xl font-bold text-navy mb-2">{formTitle}</h3>
  <p class="text-sm text-gray-500 mb-6">Un conseiller vous recontacte sous 24h. Sans engagement.</p>

  <form id={id} class="space-y-4" novalidate>
    <input type="hidden" name="type" value={source} />
    {/* Honeypot */}
    <div class="hidden" aria-hidden="true">
      <input type="text" name="_honeypot" tabindex="-1" autocomplete="off" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for={`nom-${id}`} class="block text-sm font-medium text-navy mb-1">Nom complet</label>
        <input
          type="text"
          id={`nom-${id}`}
          name="nom"
          required
          class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
          placeholder="Jean Dupont"
        />
      </div>
      <div>
        <label for={`email-${id}`} class="block text-sm font-medium text-navy mb-1">Email</label>
        <input
          type="email"
          id={`email-${id}`}
          name="email"
          required
          class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
          placeholder="jean@email.com"
        />
      </div>
    </div>

    <div>
      <label for={`tel-${id}`} class="block text-sm font-medium text-navy mb-1">Téléphone</label>
      <input
        type="tel"
        id={`tel-${id}`}
        name="telephone"
        class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
        placeholder="06 12 34 56 78"
      />
    </div>

    {/* Champs spécifiques crédit immobilier */}
    {source === 'credit-immobilier' && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for={`montant-${id}`} class="block text-sm font-medium text-navy mb-1">Montant souhaité (€)</label>
          <input
            type="number"
            id={`montant-${id}`}
            name="montant"
            min="10000"
            step="5000"
            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
            placeholder="250 000"
          />
        </div>
        <div>
          <label for={`duree-${id}`} class="block text-sm font-medium text-navy mb-1">Durée souhaitée (années)</label>
          <input
            type="number"
            id={`duree-${id}`}
            name="duree"
            min="5"
            max="30"
            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
            placeholder="20"
          />
        </div>
      </div>
    )}

    {/* Champ spécifique rachat crédit */}
    {source === 'rachat-credit' && (
      <div>
        <label for={`montant-${id}`} class="block text-sm font-medium text-navy mb-1">Montant total des crédits (€)</label>
        <input
          type="number"
          id={`montant-${id}`}
          name="montant"
          min="1000"
          step="1000"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition"
          placeholder="80 000"
        />
      </div>
    )}

    {/* Champ message pour défiscalisation */}
    {source === 'defiscalisation' && (
      <div>
        <label for={`msg-${id}`} class="block text-sm font-medium text-navy mb-1">Votre situation</label>
        <textarea
          id={`msg-${id}`}
          name="message"
          rows="3"
          class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gold/20 focus:border-gold outline-none transition resize-none"
          placeholder="Décrivez brièvement votre situation fiscale et vos objectifs..."
        ></textarea>
      </div>
    )}

    <button type="submit" class="btn-primary w-full">
      {submitLabel}
    </button>

    {/* Status messages */}
    <div id={`${id}-success`} class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 text-sm text-center">
      Votre demande a bien été envoyée. Un conseiller vous recontactera sous 24h.
    </div>
    <div id={`${id}-error`} class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 text-sm text-center">
      Une erreur est survenue. Veuillez réessayer ou nous contacter à contact@finaneo.fr.
    </div>

    <p class="text-xs text-gray-400 text-center">
      En soumettant ce formulaire, vous acceptez notre <a href="/politique-confidentialite/" class="underline hover:text-gold">politique de confidentialité</a>.
    </p>
  </form>
</div>

<script define:vars={{ id }}>
  const form = document.getElementById(id);
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formEl = e.target;
    const btn = formEl.querySelector('button[type="submit"]');
    const successEl = document.getElementById(`${id}-success`);
    const errorEl = document.getElementById(`${id}-error`);

    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    const fd = new FormData(formEl);
    const body = Object.fromEntries(fd.entries());

    try {
      const res = await fetch('/.netlify/functions/send-contact-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        successEl?.classList.remove('hidden');
        formEl.reset();
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });
</script>
