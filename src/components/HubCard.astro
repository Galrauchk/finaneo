---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl border border-gray-200 p-6 hover:border-gold hover:shadow-lg transition-all duration-200">
  <div class="text-3xl mb-4">{icon}</div>
  <h3 class="text-lg font-bold text-navy mb-2 group-hover:text-gold transition-colors">{title}</h3>
  <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
  <span class="inline-flex items-center gap-1 text-gold text-sm font-medium mt-4">
    Découvrir
    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
