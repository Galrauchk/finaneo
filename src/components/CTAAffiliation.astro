---
interface Props {
  title?: string;
  description?: string;
  buttonLabel?: string;
  buttonHref?: string;
  partner?: string;
}

const {
  title = 'Comparez les meilleures offres',
  description = 'Trouvez l\'offre la plus adaptée à votre profil parmi nos partenaires sélectionnés.',
  buttonLabel = 'Voir les offres',
  buttonHref = '#',
  partner = 'Partenaire',
} = Astro.props;
---

<div class="bg-gradient-to-r from-navy to-blue-900 rounded-2xl p-8 text-white">
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gold mb-2 block">{partner}</span>
      <h3 class="text-xl font-bold mb-2">{title}</h3>
      <p class="text-gray-300 text-sm">{description}</p>
    </div>
    <a
      href={buttonHref}
      target="_blank"
      rel="noopener noreferrer sponsored"
      class="btn-primary whitespace-nowrap"
    >
      {buttonLabel}
    </a>
  </div>
</div>
