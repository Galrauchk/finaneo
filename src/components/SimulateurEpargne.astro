---
---

<div id="sim-epargne" class="bg-white rounded-2xl border border-gray-200 p-8">
  <h2 class="text-xl font-bold text-navy mb-6">Simulez la croissance de votre épargne</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div>
      <label for="capital-initial" class="block text-sm font-medium text-dark mb-1">Capital initial (€)</label>
      <input type="number" id="capital-initial" value="10000" min="0" max="10000000" step="500"
        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none" />
    </div>
    <div>
      <label for="versement" class="block text-sm font-medium text-dark mb-1">Versement mensuel (€)</label>
      <input type="number" id="versement" value="200" min="0" max="50000" step="50"
        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none" />
    </div>
    <div>
      <label for="taux-epargne" class="block text-sm font-medium text-dark mb-1">Taux annuel (%)</label>
      <input type="number" id="taux-epargne" value="2.5" min="0" max="15" step="0.1"
        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none" />
    </div>
    <div>
      <label for="duree-epargne" class="block text-sm font-medium text-dark mb-1">Durée (années)</label>
      <input type="number" id="duree-epargne" value="10" min="1" max="50" step="1"
        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-gold focus:border-gold outline-none" />
    </div>
  </div>

  <button id="btn-calc-epargne" class="btn-primary mb-8">Calculer</button>

  <div id="result-epargne" class="hidden bg-light rounded-xl p-6 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div>
        <p class="text-sm text-gray-500 mb-1">Capital final</p>
        <p id="res-capital" class="text-2xl font-bold text-navy">—</p>
      </div>
      <div>
        <p class="text-sm text-gray-500 mb-1">Total versé</p>
        <p id="res-verse" class="text-2xl font-bold text-gray-600">—</p>
      </div>
      <div>
        <p class="text-sm text-gray-500 mb-1">Intérêts générés</p>
        <p id="res-interets" class="text-2xl font-bold text-gold">—</p>
      </div>
    </div>
  </div>
</div>

<script>
  function calcEpargne() {
    const capital = parseFloat((document.getElementById('capital-initial') as HTMLInputElement).value);
    const versement = parseFloat((document.getElementById('versement') as HTMLInputElement).value);
    const tauxAnnuel = parseFloat((document.getElementById('taux-epargne') as HTMLInputElement).value);
    const duree = parseFloat((document.getElementById('duree-epargne') as HTMLInputElement).value);

    if (isNaN(capital) || isNaN(versement) || isNaN(tauxAnnuel) || isNaN(duree)) return;

    const tauxMensuel = tauxAnnuel / 100 / 12;
    const nbMois = duree * 12;

    let solde = capital;
    for (let i = 0; i < nbMois; i++) {
      solde = solde * (1 + tauxMensuel) + versement;
    }

    const totalVerse = capital + versement * nbMois;
    const interets = solde - totalVerse;

    const fmt = (n: number) => new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);

    document.getElementById('res-capital')!.textContent = fmt(solde);
    document.getElementById('res-verse')!.textContent = fmt(totalVerse);
    document.getElementById('res-interets')!.textContent = fmt(interets);
    document.getElementById('result-epargne')!.classList.remove('hidden');
  }

  document.getElementById('btn-calc-epargne')?.addEventListener('click', calcEpargne);
  document.querySelectorAll('#sim-epargne input').forEach(input => {
    input.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') calcEpargne();
    });
  });
</script>
