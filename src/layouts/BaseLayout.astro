---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const { title, description, canonical, jsonLd, noindex } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      jsonLd={jsonLd}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
